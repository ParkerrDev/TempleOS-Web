#include "cpu.HC"

I64 g_pass, g_fail, g_total;
U0 Go(I64 maxi) { Run(maxi); g_total += icount; }
// Call a real compiled function: arg in RDI (System V), return in RAX, runs to a
// sentinel HLT placed at the pushed return address.
U0 RunFunc(U8 *p, I64 n, U64 arg, U64 at)
{
  Reset();
  reg[7] = arg;
  mem[0x4000] = 0xF4;                              // HLT at the return sentinel
  reg[4] -= 8; WrMem(reg[4], 8, 0x4000);           // push return address
  Load(p, n, at);
  Go(1000000);
}
U0 Check(U8 *name, I64 got, I64 want)
{
  if (got == want) { g_pass++; }
  else { g_fail++; "  FAIL %s: got %d want %d\n", name, got, want; }
}
U0 CheckGE(U8 *name, I64 got, I64 minv)
{
  if (got >= minv) { g_pass++; }
  else { g_fail++; "  FAIL %s: got %d want >=%d\n", name, got, minv; }
}

U8 prog_sum[19]  = {0x48,0x31,0xC0, 0x48,0xC7,0xC1,0x40,0x42,0x0F,0x00, 0x48,0x01,0xC8, 0x48,0xFF,0xC9, 0x75,0xF8, 0xF4};
U8 prog_movsb[3] = {0xF3,0xA4,0xF4};
U8 prog_shl[9]   = {0xB8,0x01,0x00,0x00,0x00, 0xC1,0xE0,0x0A, 0xF4};
U8 prog_mul[18]  = {0x48,0xC7,0xC0,0xA0,0x86,0x01,0x00, 0x48,0xC7,0xC1,0xA0,0x86,0x01,0x00, 0x48,0xF7,0xE1, 0xF4};
U8 prog_div[21]  = {0x48,0xC7,0xC0,0x40,0x42,0x0F,0x00, 0x48,0x31,0xD2, 0x48,0xC7,0xC1,0x07,0x00,0x00,0x00, 0x48,0xF7,0xF1, 0xF4};
U8 prog_call[17] = {0xE8,0x04,0x00,0x00,0x00, 0x48,0x89,0xC3, 0xF4, 0x48,0xC7,0xC0,0x2A,0x00,0x00,0x00, 0xC3};
U8 prog_max[23]  = {0x48,0xC7,0xC0,0x03,0x00,0x00,0x00, 0x48,0xC7,0xC1,0x07,0x00,0x00,0x00, 0x48,0x39,0xC8, 0x7D,0x03, 0x48,0x89,0xC8, 0xF4};
U8 prog_movx[15]  = {0x48,0xC7,0xC0,0xFF,0x00,0x00,0x00, 0x0F,0xB6,0xC8, 0x48,0x0F,0xBE,0xD0, 0xF4};
U8 prog_imul2[19] = {0x48,0xC7,0xC0,0x07,0x00,0x00,0x00, 0x48,0xC7,0xC1,0x06,0x00,0x00,0x00, 0x48,0x0F,0xAF,0xC1, 0xF4};
U8 prog_movsxd[9] = {0xB9,0xFF,0xFF,0xFF,0xFF, 0x48,0x63,0xC1, 0xF4};
U8 prog_cmov[22]  = {0x48,0xC7,0xC0,0x05,0x00,0x00,0x00, 0x48,0xC7,0xC1,0x09,0x00,0x00,0x00, 0x48,0x39,0xC8, 0x48,0x0F,0x4C,0xC1, 0xF4};
U8 prog_rol[12]   = {0x48,0xC7,0xC0,0x01,0x00,0x00,0x00, 0x48,0xC1,0xC0,0x04, 0xF4};
U8 prog_adc[23]   = {0x48,0xC7,0xC0,0xFF,0xFF,0xFF,0xFF, 0x48,0xC7,0xC2,0x00,0x00,0x00,0x00, 0x48,0x83,0xC0,0x01, 0x48,0x83,0xD2,0x00, 0xF4};
U8 prog_xchg[18]  = {0x48,0xC7,0xC0,0x01,0x00,0x00,0x00, 0x48,0xC7,0xC1,0x02,0x00,0x00,0x00, 0x48,0x87,0xC1, 0xF4};

// Real machine code from clang (x86-64): `long sq(long n){long s=0;for(long i=1;i<=n;i++)s+=i*i;return s;}`
// -O0 = stack-frame loop (SIB/rsp-relative + memory); -O1 = closed-form (mul + SHLD magic divide).
U8 prog_clang_o0[78] = {
  0x48,0x89,0x7C,0x24,0xF8, 0x48,0xC7,0x44,0x24,0xF0,0x00,0x00,0x00,0x00, 0x48,0xC7,0x44,0x24,0xE8,0x01,0x00,0x00,0x00,
  0x48,0x8B,0x44,0x24,0xE8, 0x48,0x3B,0x44,0x24,0xF8, 0x7F,0x25, 0x48,0x8B,0x44,0x24,0xE8,
  0x48,0x0F,0xAF,0x44,0x24,0xE8, 0x48,0x03,0x44,0x24,0xF0, 0x48,0x89,0x44,0x24,0xF0,
  0x48,0x8B,0x44,0x24,0xE8, 0x48,0x83,0xC0,0x01, 0x48,0x89,0x44,0x24,0xE8, 0xEB,0xCF,
  0x48,0x8B,0x44,0x24,0xF0, 0xC3};
U8 prog_clang_o1[65] = {
  0x48,0x85,0xFF, 0x7E,0x39, 0x48,0x8D,0x47,0xFF, 0x48,0x8D,0x4F,0xFE, 0x48,0xF7,0xE1,
  0x48,0x8D,0x4F,0xFD, 0x48,0x0F,0xAF,0xC8, 0x48,0xD1,0xE9, 0x48,0xBE,0x56,0x55,0x55,0x55,0x55,0x55,0x55,0x55,
  0x48,0x0F,0xA4,0xC2,0x3F, 0x48,0x0F,0xAF,0xF1, 0x48,0x8D,0x04,0x92, 0x48,0x01,0xF0,
  0x48,0x8D,0x04,0xB8, 0x48,0x83,0xC0,0xFD, 0xC3, 0x31,0xC0, 0xC3};

U8 prog_cr[14]    = {0x48,0xC7,0xC0,0x45,0x23,0x01,0x00, 0x0F,0x22,0xD8, 0x0F,0x20,0xDB, 0xF4};  // rax=0x12345; cr3=rax; rbx=cr3
U8 prog_msr[22]   = {0xB9,0x80,0x00,0x00,0xC0, 0xB8,0x00,0x05,0x00,0x00, 0x31,0xD2, 0x0F,0x30, 0xB8,0x00,0x00,0x00,0x00, 0x0F,0x32, 0xF4};  // wrmsr EFER=0x500; rdmsr
U8 prog_tsc[11]   = {0x0F,0x31, 0x48,0x89,0xC3, 0x0F,0x31, 0x48,0x29,0xD8, 0xF4};  // rdtsc; rbx=rax; rdtsc; rax-=rbx

// SSE2 (F64): (7.0*3.0)+1.0=22 ; 10.0/4.0 trunc=2 ; movq round-trip ; ucomisd 3<5 -> rax=1
U8 prog_fmul[50] = {0x48,0xC7,0xC0,0x07,0x00,0x00,0x00, 0xF2,0x48,0x0F,0x2A,0xC0, 0x48,0xC7,0xC0,0x03,0x00,0x00,0x00, 0xF2,0x48,0x0F,0x2A,0xC8, 0xF2,0x0F,0x59,0xC1, 0x48,0xC7,0xC0,0x01,0x00,0x00,0x00, 0xF2,0x48,0x0F,0x2A,0xC8, 0xF2,0x0F,0x58,0xC1, 0xF2,0x48,0x0F,0x2C,0xC0, 0xF4};
U8 prog_fdiv[34] = {0x48,0xC7,0xC0,0x0A,0x00,0x00,0x00, 0xF2,0x48,0x0F,0x2A,0xC0, 0x48,0xC7,0xC0,0x04,0x00,0x00,0x00, 0xF2,0x48,0x0F,0x2A,0xC8, 0xF2,0x0F,0x5E,0xC1, 0xF2,0x48,0x0F,0x2C,0xC0, 0xF4};
U8 prog_movq[18] = {0x48,0xC7,0xC0,0x78,0x56,0x34,0x12, 0x66,0x48,0x0F,0x6E,0xC0, 0x66,0x48,0x0F,0x7E,0xC3, 0xF4};
U8 prog_fcmp[45] = {0x48,0xC7,0xC0,0x03,0x00,0x00,0x00, 0xF2,0x48,0x0F,0x2A,0xC0, 0x48,0xC7,0xC0,0x05,0x00,0x00,0x00, 0xF2,0x48,0x0F,0x2A,0xC8, 0x66,0x0F,0x2E,0xC1, 0x48,0xC7,0xC0,0x00,0x00,0x00,0x00, 0x73,0x07, 0x48,0xC7,0xC0,0x01,0x00,0x00,0x00, 0xF4};

U0 Main()
{
  InitMem(4194304);
  g_pass = 0; g_fail = 0; g_total = 0;

  Reset(); Load(prog_sum, 19, 0x1000); Go(20000000); Check("sum 1..1e6", reg[0], 500000500000);

  Reset();
  mem[0x2000] = 0x11; mem[0x2001] = 0x22; mem[0x2002] = 0x33; mem[0x2003] = 0x44; mem[0x2004] = 0x55;
  reg[6] = 0x2000; reg[7] = 0x3000; reg[1] = 5;
  Load(prog_movsb, 3, 0x1000); Go(1000);
  Check("rep movsb[0]", mem[0x3000], 0x11); Check("rep movsb[4]", mem[0x3004], 0x55);

  Reset(); Load(prog_shl, 9, 0x1000);   Go(1000); Check("shl 1<<10", reg[0], 1024);
  Reset(); Load(prog_mul, 18, 0x1000);  Go(1000); Check("mul lo", reg[0], 10000000000); Check("mul hi", reg[2], 0);
  Reset(); Load(prog_div, 21, 0x1000);  Go(1000); Check("div quot", reg[0], 142857); Check("div rem", reg[2], 1);
  Reset(); Load(prog_call, 17, 0x1000); Go(1000); Check("call/ret", reg[3], 42);
  Reset(); Load(prog_max, 23, 0x1000);  Go(1000); Check("cmp/jge max", reg[0], 7);
  Reset(); Load(prog_movx, 15, 0x1000); Go(1000); Check("movzx", reg[1], 255); Check("movsx", reg[2], -1);

  Reset(); Load(prog_imul2, 19, 0x1000);  Go(1000); Check("imul r,r", reg[0], 42);
  Reset(); Load(prog_movsxd, 9, 0x1000);  Go(1000); Check("movsxd", reg[0], -1);
  Reset(); Load(prog_cmov, 22, 0x1000);   Go(1000); Check("cmovl", reg[0], 9);
  Reset(); Load(prog_rol, 12, 0x1000);    Go(1000); Check("rol", reg[0], 16);
  Reset(); Load(prog_adc, 23, 0x1000);    Go(1000); Check("adc carry", reg[2], 1); Check("adc wrap", reg[0], 0);
  Reset(); Load(prog_xchg, 18, 0x1000);   Go(1000); Check("xchg a", reg[0], 2); Check("xchg b", reg[1], 1);

  RunFunc(prog_clang_o0, 78, 10, 0x1000); Check("clang -O0 sq(10)", reg[0], 385);
  RunFunc(prog_clang_o1, 65, 10, 0x1000); Check("clang -O1 sq(10)", reg[0], 385);

  Reset(); Load(prog_cr, 14, 0x1000);  Go(1000); Check("mov cr3/rd", reg[3], 0x12345);
  Reset(); Load(prog_msr, 22, 0x1000); Go(1000); Check("wr/rdmsr EFER", reg[0], 0x500);
  Reset(); Load(prog_tsc, 11, 0x1000); Go(1000); Check("rdtsc delta", reg[0], 100);

  // INT n -> IDT gate -> handler -> IRETQ round-trip
  Reset();
  idtr_base = 0x5000; idtr_limit = 0xFFF;
  WrMem(0x5000 + 0x20*16 + 0, 2, 0x6000);   // handler offset[15:0]
  WrMem(0x5000 + 0x20*16 + 2, 2, 0x08);     // selector
  WrMem(0x5000 + 0x20*16 + 4, 2, 0x8E00);   // type = present interrupt gate
  WrMem(0x5000 + 0x20*16 + 6, 2, 0);
  WrMem(0x5000 + 0x20*16 + 8, 4, 0);
  mem[0x6000]=0x48; mem[0x6001]=0xC7; mem[0x6002]=0xC3; mem[0x6003]=0x63;  // handler: mov rbx,99
  mem[0x6004]=0; mem[0x6005]=0; mem[0x6006]=0; mem[0x6007]=0x48; mem[0x6008]=0xCF;  // iretq
  mem[0x1000]=0xCD; mem[0x1001]=0x20; mem[0x1002]=0xF4;  // int 0x20; hlt
  rip = 0x1000;
  Go(1000);
  Check("int/idt/iret", reg[3], 99);

  Reset(); Load(prog_fmul, 50, 0x1000); Go(1000); Check("sse 7.0*3+1", reg[0], 22);
  Reset(); Load(prog_fdiv, 34, 0x1000); Go(1000); Check("sse 10.0/4 trunc", reg[0], 2);
  Reset(); Load(prog_movq, 18, 0x1000); Go(1000); Check("movq xmm round", reg[3], 0x12345678);
  Reset(); Load(prog_fcmp, 45, 0x1000); Go(1000); Check("ucomisd 3<5", reg[0], 1);

  // Timer: PIT -> IRQ0 -> PIC -> IDT[0x20] -> handler increments [0x7000], EOI, IRET
  Reset();
  idtr_base = 0x5000;
  WrMem(0x5000 + 0x20*16 + 0, 2, 0x6000);
  WrMem(0x5000 + 0x20*16 + 2, 2, 0x08);
  WrMem(0x5000 + 0x20*16 + 4, 2, 0x8E00);
  mem[0x6000]=0x48; mem[0x6001]=0xFF; mem[0x6002]=0x04; mem[0x6003]=0x25;   // inc qword [0x7000]
  mem[0x6004]=0x00; mem[0x6005]=0x70; mem[0x6006]=0x00; mem[0x6007]=0x00;
  mem[0x6008]=0xB0; mem[0x6009]=0x20; mem[0x600A]=0xE6; mem[0x600B]=0x20;   // mov al,0x20; out 0x20,al (EOI)
  mem[0x600C]=0x48; mem[0x600D]=0xCF;                                       // iretq
  WrMem(0x7000, 8, 0);
  mem[0x1000]=0xFB; mem[0x1001]=0xEB; mem[0x1002]=0xFE;                     // sti; jmp $
  rip = 0x1000;
  IoOut(0x20,0x11); IoOut(0x21,0x20); IoOut(0x21,0x04); IoOut(0x21,0x01); IoOut(0x21,0xFE);  // PIC1: vec base 0x20, unmask IRQ0
  IoOut(0x43,0x34); IoOut(0x40,100); IoOut(0x40,0);                        // PIT ch0: reload 100
  Go(2000);
  CheckGE("PIT->IRQ0->handler fires", RdMem(0x7000, 8), 5);

  "hemu: %d passed, %d failed | total guest instr=%d badop=%d\n", g_pass, g_fail, g_total, g_badop;
}
Main;
