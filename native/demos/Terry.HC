U0 DancingTerry()
{
  CDC *dc=DCAlias;
  I64 frame=0, fsz=TW*TH, ch=0;
  I64 dw=TW*TS, dh=TH*TS;
  I64 px=(GR_WIDTH-dw)/2, py=(GR_HEIGHT-dh)/2;
  do {
    DCFill(dc,BLACK);
    dc->color=YELLOW;
    GrPrint(dc,(GR_WIDTH-104)/2,py-18,"Dancing Terry");
    GrSprite(dc,px,py,terry_sprite+frame*fsz,TW,TH,TS);
    frame++;
    if (frame>=TN) frame=0;
    Sleep(55);
  } while (!(ch=ScanChar) || (ch!=CH_SHIFT_ESC && ch!=CH_ESC));
  DCDel(dc);
}
