# NO cross-origin isolation: it was only ever for QEMU-WASM's SharedArrayBuffer threads,
# and QEMU is gone — the deployed HEMU engine uses plain (unshared) WASM memory and
# postMessage. Staying un-isolated lets Terry Search stream archive.org video INLINE
# (their download nodes send no CORS/CORP, which COEP would block). If SMP (shared
# guest RAM) ever ships, isolation must come back — and inline playback must move to
# the COEP-exempt player.html pattern (see git history at 73dc575).

# Long-cache the big immutable build artifacts (cache-busted by the ?v= query).
/vendor/*
  Cache-Control: public, max-age=31536000

# HEMU artifacts change every deploy — always revalidate so a cached coi-serviceworker
# can never pin users to an old (crashing) build. (This is what caused "fix deployed but
# still crashes": the SW re-fetched the stale wasm from the browser HTTP cache.)
/hemu
  Cache-Control: no-cache
/hemu.html
  Cache-Control: no-cache
/hemu-worker.js
  Cache-Control: no-cache
/coi-serviceworker.js
  Cache-Control: no-cache
/hemu-wasm/snapshot.wasm
  Cache-Control: no-cache
/hemu-wasm/live.bin.gz
  Cache-Control: no-cache
# jit.js + the compiler modules it imports must move in lockstep with snapshot.wasm's
# global offsets (G_FS/G_GS/G_TSC) — a stale jit.js corrupts segment bases (BADOP crash).
/jit.js
  Cache-Control: no-cache
/holyc-wasm/*
  Cache-Control: no-cache
