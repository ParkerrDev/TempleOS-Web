# COEP: credentialless — the best of both worlds:
#  * SharedArrayBuffer works (the HolyC editor runs blocking programs in a worker with a
#    shared framebuffer + Atomics input — it NEEDS isolation),
#  * cross-origin <video>/<img> still load (Terry Search streams archive.org originals
#    inline; their download nodes send no CORS/CORP, which require-corp would block —
#    credentialless allows no-cors media, just sent without credentials).
# Safari doesn't support credentialless: it ignores it -> not isolated -> everything works
# except the editor's runner, which already shows its own graceful warning there.
/*
  Cross-Origin-Opener-Policy: same-origin
  Cross-Origin-Embedder-Policy: credentialless

# Long-cache the big immutable build artifacts (cache-busted by the ?v= query).
/vendor/*
  Cache-Control: public, max-age=31536000

# HEMU artifacts change every deploy — always revalidate so the browser HTTP cache
# can never pin users to an old (crashing) build.
/hemu
  Cache-Control: no-cache
/hemu.html
  Cache-Control: no-cache
/hemu-worker.js
  Cache-Control: no-cache
/hemu-wasm/*
  Cache-Control: no-cache
# hemu-wasm/jit.js + the compiler modules it imports must move in lockstep with snapshot.wasm's
# global offsets (G_FS/G_GS/G_TSC) — a stale jit.js corrupts segment bases (BADOP crash).
/holyc-wasm/*
  Cache-Control: no-cache
